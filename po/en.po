#: extension.js:39
msgid "Leer selección"
msgstr "Read selection"

#: extension.js:43
msgid "Detener"
msgstr "Stop"

#: extension.js:147
msgid "No se encontró texto en la selección"
msgstr "No text found in selection"

#: extension.js:202
msgid "[Plane TTS] No hay texto seleccionado"
msgstr "[Plane TTS] No text selected"

#: prefs.js:20
msgid "Voz"
msgstr "Voice"

#: prefs.js:27
msgid "Modo de voz"
msgstr "Voice Mode"

#: prefs.js:28
msgid "Elige cómo se genera la voz"
msgstr "Choose how the voice is generated"

#: prefs.js:33
msgid "Modo"
msgstr "Mode"

#: prefs.js:35
msgid ""
"Clonar usa un audio de referencia, Diseñar usa una descripción de texto, "
"Auto deja que el modelo decida"
msgstr ""
"Clone uses a reference audio, Design uses a text description, Auto lets the "
"model decide"

#: prefs.js:54
msgid "Clonación de voz"
msgstr "Voice Cloning"

#: prefs.js:56
msgid ""
"Usa un audio de referencia para clonar una voz. Deja el texto de referencia "
"vacío para auto-transcripción (Whisper)."
msgstr ""
"Use a reference audio to clone a voice. Leave reference text empty for auto-"
"transcription (Whisper)."

#: prefs.js:63
msgid "Audio de referencia"
msgstr "Reference Audio"

#: prefs.js:66 prefs.js:113
msgid "Ningún archivo seleccionado"
msgstr "No file selected"

#: prefs.js:70
msgid "Elegir archivo"
msgstr "Choose File"

#: prefs.js:75
msgid "Seleccionar audio de referencia"
msgstr "Select Reference Audio"

#: prefs.js:79
msgid "Archivos de audio"
msgstr "Audio Files"

#: prefs.js:109
msgid "Limpiar"
msgstr "Clear"

#: prefs.js:122
msgid "Texto de referencia (opcional)"
msgstr "Reference Text (optional)"

#: prefs.js:133
msgid "Diseño de voz"
msgstr "Voice Design"

#: prefs.js:134
msgid "Describe las características de voz deseadas"
msgstr "Describe the desired voice characteristics"

#: prefs.js:139
msgid "Descripción de voz"
msgstr "Voice Description"

#: prefs.js:153
msgid "Parámetros"
msgstr "Parameters"

#: prefs.js:159
msgid "Parámetros de generación"
msgstr "Generation Parameters"

#: prefs.js:160
msgid "Parámetros avanzados para la generación de audio"
msgstr "Advanced parameters for audio generation"

#: prefs.js:166
msgid "Pasos de difusión"
msgstr "Diffusion Steps"

#: prefs.js:168
msgid "Mayor = mejor calidad pero más lento (16 para rápido, 32 para calidad)"
msgstr "Higher = better quality but slower (16 for fast, 32 for quality)"

#: prefs.js:188
msgid "Velocidad"
msgstr "Speed"

#: prefs.js:189
msgid "> 1.0 = habla más rápida, < 1.0 = habla más lenta"
msgstr "> 1.0 = faster speech, < 1.0 = slower speech"

#: prefs.js:204
msgid "Escala de guía"
msgstr "Guidance Scale"

#: prefs.js:205
msgid "Escala de guía libre de clasificador"
msgstr "Classifier-free guidance scale"

#: prefs.js:225
msgid "Atajo"
msgstr "Shortcut"

#: prefs.js:231
msgid "Atajo de teclado"
msgstr "Keyboard Shortcut"

#: prefs.js:232
msgid "Atajo para leer el texto seleccionado en voz alta"
msgstr "Shortcut to read the selected text aloud"

#: prefs.js:238
msgid "Atajo TTS"
msgstr "TTS Shortcut"

#: prefs.js:240
msgid "No configurado"
msgstr "Not set"
