#: extension.js:38
msgid "Read Selection"
msgstr "Leer selección"

#: extension.js:42
msgid "Stop"
msgstr "Detener"

#: extension.js:48
msgid "Settings"
msgstr "Ajustes"

#: extension.js:152
msgid "No text found in selection"
msgstr "No se encontró texto en la selección"

#: extension.js:207
msgid "[Plane TTS] No text selected"
msgstr "[Plane TTS] No hay texto seleccionado"

#: prefs.js:20
msgid "Voice"
msgstr "Voz"

#: prefs.js:27
msgid "Voice Mode"
msgstr "Modo de voz"

#: prefs.js:28
msgid "Choose how the voice is generated"
msgstr "Elige cómo se genera la voz"

#: prefs.js:33
msgid "Mode"
msgstr "Modo"

#: prefs.js:35
msgid ""
"Clone uses a reference audio, Design uses a text description, Auto lets the "
"model decide"
msgstr ""
"Clonar usa un audio de referencia, Diseñar usa una descripción de texto, "
"Auto deja que el modelo decida"

#: prefs.js:54
msgid "Voice Cloning"
msgstr "Clonación de voz"

#: prefs.js:56
msgid ""
"Use a reference audio to clone a voice. Leave the reference text empty for "
"auto-transcription (Whisper)."
msgstr ""
"Usa un audio de referencia para clonar una voz. Deja el texto de referencia "
"vacío para auto-transcripción (Whisper)."

#: prefs.js:63
msgid "Reference Audio"
msgstr "Audio de referencia"

#: prefs.js:66 prefs.js:113
msgid "No file selected"
msgstr "Ningún archivo seleccionado"

#: prefs.js:70
msgid "Choose File"
msgstr "Elegir archivo"

#: prefs.js:75
msgid "Select Reference Audio"
msgstr "Seleccionar audio de referencia"

#: prefs.js:79
msgid "Audio Files"
msgstr "Archivos de audio"

#: prefs.js:109
msgid "Clear"
msgstr "Limpiar"

#: prefs.js:122
msgid "Reference Text (optional)"
msgstr "Texto de referencia (opcional)"

#: prefs.js:133
msgid "Voice Design"
msgstr "Diseño de voz"

#: prefs.js:134
msgid "Describe the desired voice characteristics"
msgstr "Describe las características de voz deseadas"

#: prefs.js:139
msgid "Voice Description"
msgstr "Descripción de voz"

#: prefs.js:153
msgid "Parameters"
msgstr "Parámetros"

#: prefs.js:159
msgid "Generation Parameters"
msgstr "Parámetros de generación"

#: prefs.js:160
msgid "Advanced parameters for audio generation"
msgstr "Parámetros avanzados para la generación de audio"

#: prefs.js:166
msgid "Diffusion Steps"
msgstr "Pasos de difusión"

#: prefs.js:168
msgid "Higher = better quality but slower (16 for fast, 32 for quality)"
msgstr "Mayor = mejor calidad pero más lento (16 para rápido, 32 para calidad)"

#: prefs.js:188
msgid "Speed"
msgstr "Velocidad"

#: prefs.js:189
msgid "> 1.0 = faster speech, < 1.0 = slower speech"
msgstr "> 1.0 = habla más rápida, < 1.0 = habla más lenta"

#: prefs.js:204
msgid "Guidance Scale"
msgstr "Escala de guía"

#: prefs.js:205
msgid "Classifier-free guidance scale"
msgstr "Escala de guía libre de clasificador"

#: prefs.js:225
msgid "Python"
msgstr "Python"

#: prefs.js:227
msgid ""
"Path to the Python binary with OmniVoice installed (virtualenv). Replace "
"[USER] with your username."
msgstr ""
"Ruta al binario de Python con OmniVoice instalado (virtualenv). Reemplazar "
"[USER] por tu nombre de usuario."

#: prefs.js:233
msgid "Python Path"
msgstr "Ruta de Python"

