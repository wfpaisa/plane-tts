#: extension.js:38
msgid "Read Selection"
msgstr "Leer selección"

#: extension.js:42
msgid "Stop"
msgstr "Detener"

#: extension.js:48
msgid "Settings"
msgstr "Ajustes"

#: extension.js:152
msgid "No text found in selection"
msgstr "No se encontró texto en la selección"

#: extension.js:207
msgid "[Plane TTS] No text selected"
msgstr "[Plane TTS] No hay texto seleccionado"

#: prefs.js:21
msgid "Voice"
msgstr "Voz"

#: prefs.js:28
msgid "Voice Mode"
msgstr "Modo de voz"

#: prefs.js:30
msgid "Select the method used to generate the voice that will read your text"
msgstr "Selecciona el método para generar la voz que leerá tu texto"

#: prefs.js:36
msgid "Mode"
msgstr "Modo"

#: prefs.js:38
msgid ""
"Clone: imitates a voice from an audio sample. Design: creates a voice from a "
"written description. Auto: the system chooses automatically"
msgstr ""
"Clonar: imita una voz a partir de una muestra de audio. Diseñar: crea una "
"voz a partir de una descripción escrita. Auto: el sistema elige "
"automáticamente"

#: prefs.js:57
msgid "Voice Cloning"
msgstr "Clonación de voz"

#: prefs.js:59
msgid ""
"Upload a short audio sample of the voice you want to imitate. Optionally "
"write what is said in the audio, or leave it empty to detect it "
"automatically."
msgstr ""
"Sube una muestra corta de audio de la voz que quieres imitar. Opcionalmente "
"escribe lo que se dice en el audio, o déjalo vacío para detectarlo "
"automáticamente."

#: prefs.js:66
msgid "Reference Audio"
msgstr "Audio de referencia"

#: prefs.js:67 prefs.js:117 prefs.js:432
msgid "No file selected"
msgstr "Ningún archivo seleccionado"

#: prefs.js:69
msgid "A short audio file (WAV, MP3, FLAC) with the voice you want to clone"
msgstr ""
"Un archivo de audio corto (WAV, MP3, FLAC) con la voz que quieres clonar"

#: prefs.js:74
msgid "Choose File"
msgstr "Elegir archivo"

#: prefs.js:79
msgid "Select Reference Audio"
msgstr "Seleccionar audio de referencia"

#: prefs.js:83
msgid "Audio Files"
msgstr "Archivos de audio"

#: prefs.js:113
msgid "Clear"
msgstr "Limpiar"

#: prefs.js:126
msgid "Reference Text (optional)"
msgstr "Texto de referencia (opcional)"

#: prefs.js:130
msgid ""
"Transcript of the reference audio. Leave empty to auto-transcribe via ASR "
"models."
msgstr ""
"Transcripción del audio de referencia. Déjalo vacío para auto-transcribir "
"con modelos ASR."

#: prefs.js:140
msgid "Voice Design"
msgstr "Diseño de voz"

#: prefs.js:142
msgid ""
"Build a voice description by selecting attributes below. The preview shows "
"what will be sent to the model."
msgstr ""
"Construye una descripción de voz seleccionando atributos. La vista previa "
"muestra lo que se enviará al modelo."

#: prefs.js:149
msgid "Freeform mode"
msgstr "Modo libre"

#: prefs.js:151
msgid "Enable to type your own description instead of using selectors"
msgstr "Activa para escribir tu propia descripción en vez de usar selectores"

#: prefs.js:158
msgid "Custom description"
msgstr "Descripción personalizada"

#: prefs.js:203
msgid "Preview"
msgstr "Vista previa"

#: prefs.js:222
msgid "(empty — model will choose defaults)"
msgstr "(vacío — el modelo elegirá valores por defecto)"

#: prefs.js:239
msgid "Gender"
msgstr "Género"

#: prefs.js:241 prefs.js:252 prefs.js:263 prefs.js:274 prefs.js:285
#: prefs.js:354
msgid "Auto"
msgstr "Auto"

#: prefs.js:250
msgid "Age"
msgstr "Edad"

#: prefs.js:261
msgid "Pitch"
msgstr "Tono"

#: prefs.js:272
msgid "Style"
msgstr "Estilo"

#: prefs.js:283
msgid "English Accent"
msgstr "Acento inglés"

#: prefs.js:314
msgid "Tips"
msgstr "Consejos"

#: prefs.js:316
msgid ""
"Combine freely across categories. Leave attributes as Auto to let the model "
"decide. English accents only apply to English speech."
msgstr ""
"Combina libremente entre categorías. Deja los atributos en Auto para que el "
"modelo decida. Los acentos ingleses solo aplican a voz en inglés."

#: prefs.js:326 prefs.js:377
msgid "Language"
msgstr "Idioma"

#: prefs.js:355
msgid "English (en)"
msgstr "Inglés (en)"

#: prefs.js:356
msgid "Chinese (zh)"
msgstr "Chino (zh)"

#: prefs.js:357
msgid "Japanese (ja)"
msgstr "Japonés (ja)"

#: prefs.js:358
msgid "Spanish (es)"
msgstr "Español (es)"

#: prefs.js:359
msgid "French (fr)"
msgstr "Francés (fr)"

#: prefs.js:360
msgid "German (de)"
msgstr "Alemán (de)"

#: prefs.js:361
msgid "Russian (ru)"
msgstr "Ruso (ru)"

#: prefs.js:362
msgid "Portuguese (pt)"
msgstr "Portugués (pt)"

#: prefs.js:363
msgid "Cantonese (yue)"
msgstr "Cantonés (yue)"

#: prefs.js:364
msgid "Thai (th)"
msgstr "Tailandés (th)"

#: prefs.js:365
msgid "Italian (it)"
msgstr "Italiano (it)"

#: prefs.js:366
msgid "Korean (ko)"
msgstr "Coreano (ko)"

#: prefs.js:367
msgid "Vietnamese (vi)"
msgstr "Vietnamita (vi)"

#: prefs.js:368
msgid "Indonesian (id)"
msgstr "Indonesio (id)"

#: prefs.js:369
msgid "Norwegian (no)"
msgstr "Noruego (no)"

#: prefs.js:370
msgid "Catalan (ca)"
msgstr "Catalán (ca)"

#: prefs.js:371
msgid "Croatian (hr)"
msgstr "Croata (hr)"

#: prefs.js:372
msgid "Lithuanian (lt)"
msgstr "Lituano (lt)"

#: prefs.js:373
msgid "Slovak (sk)"
msgstr "Eslovaco (sk)"

#: prefs.js:374
msgid "Swedish (sv)"
msgstr "Sueco (sv)"

#: prefs.js:378
msgid "Keep as Auto to auto-detect the language"
msgstr "Dejar en Auto para detectar el idioma automáticamente"

#: prefs.js:393
msgid "Parameters"
msgstr "Parámetros"

#: prefs.js:403
msgid "Reset All Settings"
msgstr "Restablecer todos los ajustes"

#: prefs.js:404
msgid "Restore all parameters to their default values"
msgstr "Restaurar todos los parámetros a sus valores por defecto"

#: prefs.js:407
msgid "Reset"
msgstr "Restablecer"

#: prefs.js:448
msgid "Generation Parameters"
msgstr "Parámetros de generación"

#: prefs.js:450
msgid ""
"Adjust these values to control the quality and speed of the generated audio"
msgstr ""
"Ajusta estos valores para controlar la calidad y velocidad del audio generado"

#: prefs.js:457
msgid "Speed"
msgstr "Velocidad"

#: prefs.js:459
msgid "1.0 = normal. >1 faster, <1 slower. Ignored if Duration is set."
msgstr ""
"1.0 = normal. >1 más rápido, <1 más lento. Se ignora si Duración está "
"configurada."

#: prefs.js:475
msgid "Duration (seconds)"
msgstr "Duración (segundos)"

#: prefs.js:479
msgid ""
"Leave as 0 to use speed. Set a fixed duration in seconds to override speed."
msgstr ""
"Dejar en 0 para usar velocidad. Configurar una duración fija en segundos "
"para anular la velocidad."

#: prefs.js:491
msgid "Inference Steps"
msgstr "Pasos de inferencia"

#: prefs.js:492
msgid "Default: 32. Lower = faster, higher = better quality."
msgstr "Por defecto: 32. Menor = más rápido, mayor = mejor calidad."

#: prefs.js:511
msgid "Guidance Scale (CFG)"
msgstr "Escala de guía (CFG)"

#: prefs.js:512
msgid "Default: 2.0."
msgstr "Por defecto: 2.0."

#: prefs.js:532
msgid "Processing"
msgstr "Procesamiento"

#: prefs.js:538
msgid "Denoise"
msgstr "Eliminar ruido"

#: prefs.js:539
msgid "Remove noise from generated audio. Disable for raw output."
msgstr ""
"Elimina el ruido del audio generado. Desactivar para salida sin procesar."

#: prefs.js:551
msgid "Preprocess Prompt"
msgstr "Preprocesar prompt"

#: prefs.js:553
msgid ""
"Apply silence removal and trimming to reference audio, add punctuation to "
"reference text."
msgstr ""
"Aplica eliminación de silencios y recorte al audio de referencia, agrega "
"puntuación al texto de referencia."

#: prefs.js:566
msgid "Postprocess Output"
msgstr "Posprocesar salida"

#: prefs.js:567
msgid "Remove long silences from generated audio."
msgstr "Elimina silencios largos del audio generado."

#: prefs.js:579
msgid "Model"
msgstr "Modelo"

#: prefs.js:585
msgid "OmniVoice Model"
msgstr "Modelo OmniVoice"

#: prefs.js:587
msgid ""
"Location of the Python program that runs the voice model. Replace [USER] in "
"the path with your system username."
msgstr ""
"Ubicación del programa Python que ejecuta el modelo de voz. Reemplaza [USER] "
"en la ruta por tu nombre de usuario del sistema."

#: prefs.js:593
msgid "Python Path"
msgstr "Ruta de Python"

#: prefs.js:597
msgid ""
"Full path to the Python executable inside the OmniVoice virtual environment"
msgstr ""
"Ruta completa al ejecutable de Python dentro del entorno virtual de OmniVoice"

#: prefs.js:606
msgid "Installation"
msgstr "Instalación"

#: prefs.js:608
msgid "To install OmniVoice, run these commands in a terminal:"
msgstr "Para instalar OmniVoice, ejecuta estos comandos en una terminal:"

#: prefs.js:614
msgid "Commands"
msgstr "Comandos"

#: prefs.js:621
msgid "Documentation"
msgstr "Documentación"

#: prefs.js:626
msgid "Repository"
msgstr "Repositorio"

#: prefs.js:634
msgid "Shortcut"
msgstr "Atajo"

#: prefs.js:640
msgid "Keyboard Shortcut"
msgstr "Atajo de teclado"

#: prefs.js:642
msgid "Select any text on screen and press this shortcut to hear it read aloud"
msgstr ""
"Selecciona cualquier texto en pantalla y presiona este atajo para escucharlo "
"en voz alta"

#: prefs.js:650
msgid "Not configured"
msgstr "No configurado"

#: prefs.js:655
msgid "TTS Shortcut"
msgstr "Atajo TTS"

#: prefs.js:657
msgid ""
"Press the keyboard icon to change the shortcut, or the clear icon to restore "
"the default"
msgstr ""
"Presiona el ícono de teclado para cambiar el atajo, o el ícono de limpiar "
"para restaurar el valor por defecto"

#: prefs.js:665
msgid "Set shortcut"
msgstr "Configurar atajo"

#: prefs.js:669
msgid "Set TTS Shortcut"
msgstr "Configurar atajo TTS"

#: prefs.js:670
msgid "Press the desired key combination…"
msgstr "Presiona la combinación de teclas deseada…"

#: prefs.js:674
msgid "Cancel"
msgstr "Cancelar"

#: prefs.js:701
msgid "Reset to default"
msgstr "Restablecer al valor por defecto"

